# Environment variables prefixed with VITE_ are exposed to client code
# via import.meta.env.VITE_*
# See: https://vitejs.dev/guide/env-and-mode

# API base URL (example: Supabase, Firebase, custom backend)
# VITE_API_URL=https://api.example.com

# Feature flags
# VITE_ENABLE_ANALYTICS=true

# Platform is set automatically by build scripts — do not override here.
# PLATFORM=web
